#!/usr/bin/env bash
# Source file này trước khi mở jupyter:  `source env.sh`
# Copy sang env.sh và điền key thực — env.sh đã được gitignore (KHÔNG commit).

export INTENT_REPO="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# === LLM provider ===
export USE_OPENAI=true
export OPENAI_MODEL=gpt-4o-mini
export OPENAI_API_KEY=""               # sk-...   ← dán key OpenAI vào đây
export OPENAI_TEMPERATURE=0
export OPENAI_MAX_RETRIES=3

# === Gemini (intent_labeling_gemini_2_5_pro_eval.ipynb) ===
export GEMINI_API_KEY=""               # AIza... ← dán key Google AI / Gemini vào đây
export GEMINI_MODEL=gemini-2.5-pro
export GEMINI_TEMPERATURE=0
export GEMINI_MAX_RETRIES=3
export GEMINI_MAX_OUTPUT_TOKENS=512

# === MongoDB Atlas ===
export MONGODB_URI=""                  # mongodb+srv://user:pass@cluster.mongodb.net/...
export MONGODB_DB=intent_kb

# === Embedding rebuild ===
# Đặt =1 khi vừa rebuild graph từ unified_intents.csv để force re-embed.
export FORCE_REEMBED=0

# === HuggingFace cache (tùy chọn) ===
# export HF_HOME="$INTENT_REPO/.hf_cache"

echo "✅ Loaded env for: $INTENT_REPO"
echo "   USE_OPENAI=$USE_OPENAI  OPENAI_MODEL=$OPENAI_MODEL"
echo "   OPENAI_API_KEY set: $([ -n "$OPENAI_API_KEY" ] && echo yes || echo no)"
echo "   GEMINI_MODEL=$GEMINI_MODEL"
echo "   GEMINI_API_KEY set: $([ -n "$GEMINI_API_KEY" ] && echo yes || echo no)"
echo "   MONGODB_URI   set: $([ -n "$MONGODB_URI" ]   && echo yes || echo no)"
